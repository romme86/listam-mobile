{
  "private": true,
  "name": "listam-mobile",
  "description": "A minimalistic p2p list app",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "npm run bundle:backend:android && expo run:android",
    "android:release": "cd android && ./gradlew bundleRelease",
    "ios": "npm run bundle:backend:ios && expo run:ios --device",
    "test:grocery": "node scripts/test-grocery-intelligence.mjs",
    "test:security": "node --test backend/lib/*.test.mjs",
    "test": "npm run test:security && npm run test:grocery",
    "lint": "eslint .",
    "check:deps": "node scripts/check-deps.mjs",
    "check:secrets": "node scripts/check-secrets.mjs",
    "typecheck": "tsc --noEmit",
    "ci": "npm run lint && npm run check:deps && npm run check:secrets && npm run test",
    "bundle:backend:ios": "npx bare-pack --target ios --linked backend/backend.mjs --encoding base64 --out app/app.ios.bundle && node scripts/wrap-bare-bundle.mjs app/app.ios.bundle app/app.ios.bundle.mjs",
    "bundle:backend:android": "npx bare-pack --target android --linked backend/backend.mjs --encoding base64 --out app/assets/backend.android.bundle && node scripts/wrap-bare-bundle.mjs app/assets/backend.android.bundle app/assets/backend.android.bundle.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.0",
    "@inquirer/prompts": "^7.8.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "1.16.3",
    "autobase": "^7.20.0",
    "autopass": "^2.2.1",
    "b4a": "^1.7.1",
    "bare-crypto": "^1.12.0",
    "bare-fs": "^4.4.4",
    "bare-path": "^3.0.1",
    "bare-rpc": "^0.2.12",
    "bare-url": "^2.4.3",
    "base64-js": "^1.5.1",
    "blind-pairing": "^2.3.1",
    "blind-peering": "^1.13.0",
    "corestore": "^7.5.0",
    "expo": "~54.0.31",
    "expo-build-properties": "1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "~15.0.8",
    "expo-linking": "8.0.11",
    "expo-router": "6.0.21",
    "expo-secure-store": "~15.0.8",
    "expo-system-ui": "6.0.9",
    "hypercore-crypto": "^3.6.1",
    "hyperdb": "^4.19.0",
    "hyperdispatch": "^1.4.4",
    "hyperschema": "^1.17.0",
    "hyperswarm": "^4.12.1",
    "lucide-react-native": "^0.553.0",
    "make-dir": "^5.1.0",
    "protomux-wakeup": "^2.6.1",
    "qrcode-terminal": "^0.12.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-b4a": "0.0.4",
    "react-native-bare-kit": "0.11.5",
    "react-native-iap": "^14.7.7",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "5.6.2",
    "react-native-svg": "^15.12.1",
    "react-native-worklets": "0.5.1",
    "sodium-universal": "^5.0.1",
    "z32": "^1.1.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@types/b4a": "1.6.5",
    "@types/react": "19.2.7",
    "babel-plugin-module-resolver": "^5.0.2",
    "bare-pack": "1.5.1",
    "eslint": "^9.0.0",
    "prettier": "3.7.4",
    "prettier-config-holepunch": "2.0.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.0.0"
  }
}
